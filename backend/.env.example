# ── Supabase ─────────────────────────────────────────────────────────
# Get these from: https://supabase.com → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Stripe ────────────────────────────────────────────────────────────
# Get these from: https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs from Stripe → Products (create one product per plan)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_ALL_ACCESS=price_...
STRIPE_PRICE_VIP=price_...

# ── Discord ───────────────────────────────────────────────────────────
# Get from: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your-bot-token
DISCORD_GUILD_ID=your-server-id

# Role IDs — right-click each role in Discord → Copy ID (enable Dev Mode first)
DISCORD_ROLE_STARTER=role-id-here
DISCORD_ROLE_ALL_ACCESS=role-id-here
DISCORD_ROLE_VIP=role-id-here

# ── Bunny.net (video CDN) ─────────────────────────────────────────────
# Get from: https://dash.bunny.net → Stream → Library → API Key
BUNNY_API_KEY=your-bunny-api-key
BUNNY_LIBRARY_ID=your-library-id
BUNNY_CDN_HOSTNAME=your-pullzone.b-cdn.net

# ── App ───────────────────────────────────────────────────────────────
PORT=7000
SESSION_SECRET=change-this-to-a-long-random-string-in-production
# Set to your domain in production: https://brrrr8academy.com
APP_URL=http://localhost:7000
NODE_ENV=development
